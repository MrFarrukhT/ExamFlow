{
  "version": 2,
  "functions": {
    "api/submissions.js": {
      "runtime": "nodejs18.x"
    },
    "api/hello.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/submissions",
      "dest": "/api/submissions.js"
    },
    {
      "src": "/api/hello",
      "dest": "/api/hello.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}