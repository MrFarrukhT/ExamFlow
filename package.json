{
  "name": "innovative-centre-local-server",
  "version": "1.0.0",
  "description": "Local database server for Innovative Centre Test System",
  "type": "module",
  "main": "local-database-server.js",
  "bin": "server-cjs.cjs",
  "scripts": {
    "start": "node local-database-server.js",
    "test": "curl http://localhost:3002/test",
    "build:ielts": "pkg . --targets node18-win-x64 --output IELTSSystem.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "*.html",
      "assets/**/*",
      "scripts/**/*",
      "admin/**/*",
      "templates/**/*",
      "Cambridge/**/*",
      "MOCKs/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "node-machine-id": "^1.1.12",
    "openai": "^6.14.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "esbuild": "^0.27.0",
    "open": "^8.4.2",
    "pkg": "^5.8.1"
  }
}
